{
  "name": "screenshotter-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "postinstall": "if [ \"$NODE_ENV\" != \"production\" ]; then playwright install chromium --with-deps || true; fi"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@hono/zod-validator": "^0.4.1",
    "dotenv": "^17.3.1",
    "hono": "^4.6.0",
    "hono-rate-limiter": "^0.4.2",
    "playwright-core": "^1.49.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
